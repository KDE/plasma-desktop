#: backends/kwin_wayland/kwinwaylandbackend.cpp:46
#, kde-format
msgid "Critical error on reading fundamental device infos for touchpad %1."
msgstr ""
"Error crític en llegir la informació fonamental del dispositiu per al ratolí "
"tàctil %1."

#: backends/x11/xlibbackend.cpp:69
#, kde-format
msgid "Cannot connect to X server"
msgstr "No s'ha pogut connectar amb el servidor X"

#: backends/x11/xlibbackend.cpp:80
#, kde-format
msgid "No touchpad found"
msgstr "No s'ha trobat cap ratolí tàctil"

#: backends/x11/xlibbackend.cpp:120
#, kde-format
msgid "Cannot apply touchpad configuration"
msgstr "No s'ha pogut aplicar la configuració del ratolí tàctil"

#: backends/x11/xlibbackend.cpp:134
#, kde-format
msgid "Cannot read touchpad configuration"
msgstr "No s'ha pogut llegir la configuració del ratolí tàctil"

#: backends/x11/xlibbackend.cpp:147
#, kde-format
msgid "Cannot read default touchpad configuration"
msgstr "No s'ha pogut llegir la configuració predeterminada del ratolí tàctil"

#: kcm.cpp:69
#, kde-format
msgid "Not able to select appropriate backend"
msgstr "No s'ha pogut seleccionar el dorsal adequat"

#: kcm.cpp:126
#, kde-format
msgid ""
"Error while loading values. See logs for more information. Please restart "
"this configuration module."
msgstr ""
"Error en carregar els valors. Vegeu els registres per a més informació. "
"Torneu a iniciar aquest mòdul de configuració."

#: kcm.cpp:129
#, kde-format
msgid "No pointer device found. Connect now."
msgstr "No s'ha trobat cap dispositiu apuntador. Connecteu-lo ara."

#: kcm.cpp:138
#, kde-format
msgid ""
"Not able to save all changes. See logs for more information. Please restart "
"this configuration module and try again."
msgstr ""
"No s'han pogut desar tots els canvis. Vegeu els registres per a més "
"informació. Torneu a iniciar aquest mòdul de configuració i proveu-ho un "
"altre cop."

#: kcm.cpp:157
#, kde-format
msgid ""
"Error while loading default values. Failed to set some options to their "
"default values."
msgstr ""
"Error en carregar els valors predeterminats. Ha fallat en establir diverses "
"opcions als seus valors predeterminats."

#: kcm.cpp:172
#, kde-format
msgid ""
"Error while adding newly connected device. Please reconnect it and restart "
"this configuration module."
msgstr ""
"Error en afegir un dispositiu connectat nou. Torneu a connectar-lo i "
"reinicieu aquest mòdul de configuració."

#: kcm.cpp:185
#, kde-format
msgid "Pointer device disconnected. Closed its setting dialog."
msgstr ""
"S'ha desconnectat el dispositiu apuntador. Es tanca el seu diàleg de "
"configuració."

#: kcm.cpp:187
#, kde-format
msgid "Pointer device disconnected. No other devices found."
msgstr ""
"S'ha desconnectat el dispositiu apuntador. No s'ha trobat cap altre "
"dispositiu."

#: ui/main.qml:69
#, kde-format
msgctxt "@info:status placeholdermessage text"
msgid "No touchpad found"
msgstr "No s'ha trobat cap ratolí tàctil"

#: ui/main.qml:70
#, kde-format
msgctxt "@info:usagetip placeholdermessage explanation"
msgid "Connect an external touchpad"
msgstr "Connecta un ratolí tàctil extern"

#: ui/main.qml:87
#, kde-format
msgctxt "@label:listbox device selection"
msgid "Device:"
msgstr "Dispositiu:"

#: ui/main.qml:110
#, kde-format
msgctxt "@title:group prefix for checkbox group"
msgid "General:"
msgstr "General:"

#: ui/main.qml:111
#, kde-format
msgctxt "@option:check"
msgid "Enable device"
msgstr "Activa el dispositiu"

#: ui/main.qml:126
#, kde-format
msgctxt "@option:check"
msgid "Disable while mouse is connected"
msgstr "Desactiva mentre el ratolí està endollat"

#: ui/main.qml:146
#, kde-format
msgctxt "option:check"
msgid "Disable while typing"
msgstr "Desactiva en teclejar"

#: ui/main.qml:147
#, kde-format
msgctxt "@label 'this' refers to the 'disable touchpad while typing' feature"
msgid "This can interfere with video games."
msgstr "Això pot interferir amb els videojocs."

#: ui/main.qml:169
#, kde-format
msgctxt "@title:group"
msgid "Left and right buttons:"
msgstr "Botons esquerre i dret:"

#: ui/main.qml:170
#, kde-format
msgctxt "@option:check"
msgid "Swap (left-handed mode)"
msgstr "Intercanvia (mode esquerrà)"

#: ui/main.qml:185
#, kde-format
msgctxt "@option:check 'both' refers to the left and right buttons'"
msgid "Press both simultaneously to middle-click"
msgstr "Prémer simultàniament els dos botons fa un clic del mig"

#: ui/main.qml:197
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"Activating this setting increases click latency by 50ms. The extra delay is "
"needed to correctly detect simultaneous left and right button presses."
msgstr ""
"L'activació d'aquest paràmetre augmenta la latència del clic en 50 ms. Cal "
"un retard addicional per a detectar correctament la pressió simultània dels "
"botons esquerre i dret."

#: ui/main.qml:207
#, kde-format
msgctxt "@label:slider and @label:spinbox"
msgid "Pointer speed:"
msgstr "Velocitat del punter:"

#: ui/main.qml:287
#, kde-format
msgctxt "@option:check"
msgid "Enable pointer acceleration"
msgstr "Activa l'acceleració del punter"

#: ui/main.qml:299
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"When enabled, pointer travel distance increases with faster movement speed."
msgstr ""
"Quan està activat, la distància del moviment del punter augmenta amb una "
"velocitat de moviment més ràpida."

#: ui/main.qml:309
#, kde-format
msgctxt "@label:slider"
msgid "Scrolling speed:"
msgstr "Velocitat de desplaçament:"

#: ui/main.qml:360
#, kde-format
msgctxt "@item:inrange Slower Scroll"
msgid "Slower"
msgstr "Més lenta"

#: ui/main.qml:367
#, kde-format
msgctxt "@item:inrange Faster Scroll Speed"
msgid "Faster"
msgstr "Més ràpida"

#: ui/main.qml:374
#, kde-format
msgctxt ""
"@title group begins the sentence 'Scroll by moving two fingers anywhere/"
"moving one finger on edge'"
msgid "Scroll by:"
msgstr "Desplaçament amb:"

#: ui/main.qml:377
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'Scroll by moving two fingers anywhere'"
msgid "Moving two fingers anywhere"
msgstr "Moure dos dits a qualsevol lloc"

#: ui/main.qml:395
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'Scroll by moving one finger on edge'"
msgid "Moving one finger on edge"
msgstr "Moure un dit a la vora"

#: ui/main.qml:404
#, kde-format
msgctxt "@option:check"
msgid "Invert scroll direction (Natural scrolling)"
msgstr "Inverteix la direcció de desplaçament (desplaçament natural)"

#: ui/main.qml:421
#, kde-format
msgctxt "@option:check"
msgid "Disable horizontal scrolling"
msgstr "Desactiva el desplaçament horitzontal"

#: ui/main.qml:439
#, kde-format
msgctxt ""
"@title:group for radiobutton group, begins the sentence 'right-click by "
"pressing bottom-right corner/pressing with two fingers'"
msgid "Right-click by:"
msgstr "Clic dret amb:"

#: ui/main.qml:443
#, kde-format
msgctxt ""
"@option:radio Completes the sentence 'right-click by pressing bottom-right "
"corner'"
msgid "Pressing bottom-right corner"
msgstr "Prement la cantonada inferior dreta"

#: ui/main.qml:448
#, kde-format
msgctxt "@info:usagetip shown below radio button"
msgid "Middle-click by pressing both bottom corners."
msgstr "Clic del mig prement les dues cantonades inferiors."

#: ui/main.qml:449
#, kde-format
msgctxt "@info:usagetip shown below radio button"
msgid "Middle-click by pressing bottom center."
msgstr "Clic del mig prement el centre inferior."

#: ui/main.qml:471
#, kde-format
msgctxt ""
"@option:radio Completes the sentence 'right-click by pressing with two "
"fingers'"
msgid "Pressing anywhere with two fingers"
msgstr "Prement a qualsevol lloc amb dos dits"

#: ui/main.qml:472
#, kde-format
msgctxt "@info shown below radio button"
msgid "Middle-click by pressing anywhere with three fingers."
msgstr "Clic del mig prement a qualsevol lloc amb tres dits."

#: ui/main.qml:484
#, kde-format
msgctxt ""
"@label for radiobutton group, begins the sentence 'middle-click by pressing "
"bottom-middle edge/by pressing anywhere with three fingers'"
msgid "Middle-click by:"
msgstr "Clic del mig amb:"

#: ui/main.qml:487
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'middle-click by pressing bottom-middle "
"edge'"
msgid "Pressing bottom-middle edge"
msgstr "Prement la vora del mig inferior"

#: ui/main.qml:507
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'middle-click by pressing bottom-left "
"and bottom-right corners'"
msgid "Pressing bottom-left and bottom-right corners"
msgstr "Prement les cantonades inferiors esquerra i dreta"

#: ui/main.qml:519
#, kde-format
msgctxt ""
"@option:check completes the sentence 'middle-click by pressing anywhere with "
"three fingers'"
msgid "Pressing anywhere with three fingers"
msgstr "Prement a qualsevol lloc amb tres dits"

#: ui/main.qml:532
#, kde-format
msgctxt "@label for checkbox, tap-to-click"
msgid "Tapping:"
msgstr "Tocs:"

#: ui/main.qml:533
#, kde-format
msgctxt "@option:check"
msgid "Tap to click"
msgstr "Toc per a fer clic"

#: ui/main.qml:548
#, kde-format
msgctxt "@option:check"
msgid "Allow dragging after tapping"
msgstr "Permet arrossegar després de tocar"

#: ui/main.qml:560
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"Tap, then tap and immediately slide finger over the touchpad to drag. Lift "
"finger to drop."
msgstr ""
"Toqueu, després toqueu i llisqueu immediatament el dit sobre el ratolí "
"tàctil per a arrossegar. Aixequeu el dit per a deixar anar."

#: ui/main.qml:567
#, kde-format
msgctxt "@option:check"
msgid "Allow briefly lifting finger during tap-and-drag"
msgstr "Permet aixecar breument el dit durant el toc i l'arrossegament"

#: ui/main.qml:580
#, kde-format
msgctxt "@title:group"
msgid "Two-finger tap:"
msgstr "Toc amb dos dits:"

#: ui/main.qml:586
#, kde-format
msgctxt "@option:radio"
msgid "Right-click (three-finger tap to middle-click)"
msgstr "Clic dret (un toc amb tres dits per al clic del mig)"

#: ui/main.qml:587
#, kde-format
msgctxt "@option:radio"
msgid "Right-click"
msgstr "Clic dret"

#: ui/main.qml:608
#, kde-format
msgctxt "@option:radio"
msgid "Middle-click (three-finger tap to right-click)"
msgstr "Clic del mig (un toc amb tres dits per al clic dret)"

#: ui/main.qml:609
#, kde-format
msgctxt "@option:radio"
msgid "Middle-click"
msgstr "Clic del mig"

