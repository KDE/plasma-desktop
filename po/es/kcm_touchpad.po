#: backends/kwin_wayland/kwinwaylandbackend.cpp:46
#, kde-format
msgid "Critical error on reading fundamental device infos for touchpad %1."
msgstr ""
"Ha ocurrido un error crítico al leer información fundamental del dispositivo "
"de panel táctil %1."

#: backends/x11/xlibbackend.cpp:69
#, kde-format
msgid "Cannot connect to X server"
msgstr "No se puede conectar con el servidor X"

#: backends/x11/xlibbackend.cpp:80
#, kde-format
msgid "No touchpad found"
msgstr "No se ha encontrado ningún panel táctil"

#: backends/x11/xlibbackend.cpp:120
#, kde-format
msgid "Cannot apply touchpad configuration"
msgstr "No se puede aplicar la configuración del panel táctil"

#: backends/x11/xlibbackend.cpp:134
#, kde-format
msgid "Cannot read touchpad configuration"
msgstr "No se puede leer la configuración del panel táctil"

#: backends/x11/xlibbackend.cpp:147
#, kde-format
msgid "Cannot read default touchpad configuration"
msgstr "No se puede leer la configuración predeterminada del panel táctil"

#: kcm.cpp:69
#, kde-format
msgid "Not able to select appropriate backend"
msgstr "No se puede seleccionar el motor apropiado"

#: kcm.cpp:126
#, kde-format
msgid ""
"Error while loading values. See logs for more information. Please restart "
"this configuration module."
msgstr ""
"Ha ocurrido un error al cargar los valores. Consulte los registros para más "
"información. Por favor, reinicie este módulo de configuración."

#: kcm.cpp:129
#, kde-format
msgid "No pointer device found. Connect now."
msgstr "No se ha encontrado ningún dispositivo apuntador. Conecte uno ahora."

#: kcm.cpp:138
#, kde-format
msgid ""
"Not able to save all changes. See logs for more information. Please restart "
"this configuration module and try again."
msgstr ""
"No ha sido posible guardar todos los cambios. Consulte los registros para "
"más información. Por favor, reinicie este módulo de configuración y vuelva a "
"probar."

#: kcm.cpp:157
#, kde-format
msgid ""
"Error while loading default values. Failed to set some options to their "
"default values."
msgstr ""
"Ha ocurrido un error al cargar los valores predeterminados. Ha fallado la "
"inicialización de algunas opciones a sus valores predeterminados."

#: kcm.cpp:172
#, kde-format
msgid ""
"Error while adding newly connected device. Please reconnect it and restart "
"this configuration module."
msgstr ""
"Ha ocurrido un error al añadir el dispositivo recién conectado. Por favor, "
"vuelva a conectarlo y reinicie este módulo de configuración."

#: kcm.cpp:185
#, kde-format
msgid "Pointer device disconnected. Closed its setting dialog."
msgstr ""
"Dispositivo apuntador desconectado. Se ha cerrado su diálogo de preferencias."

#: kcm.cpp:187
#, kde-format
msgid "Pointer device disconnected. No other devices found."
msgstr ""
"Dispositivo apuntador desconectado. No se han encontrado otros dispositivos."

#: ui/main.qml:69
#, kde-format
msgctxt "@info:status placeholdermessage text"
msgid "No touchpad found"
msgstr "No se ha encontrado ningún panel táctil"

#: ui/main.qml:70
#, kde-format
msgctxt "@info:usagetip placeholdermessage explanation"
msgid "Connect an external touchpad"
msgstr "Conectar un panel táctil externo"

#: ui/main.qml:87
#, kde-format
msgctxt "@label:listbox device selection"
msgid "Device:"
msgstr "Dispositivo:"

#: ui/main.qml:110
#, kde-format
msgctxt "@title:group prefix for checkbox group"
msgid "General:"
msgstr "General:"

#: ui/main.qml:111
#, kde-format
msgctxt "@option:check"
msgid "Enable device"
msgstr "Activar dispositivo"

#: ui/main.qml:126
#, kde-format
msgctxt "@option:check"
msgid "Disable while mouse is connected"
msgstr "Desactivar cuando el ratón está conectado"

#: ui/main.qml:146
#, kde-format
msgctxt "option:check"
msgid "Disable while typing"
msgstr "Desactivar al escribir"

#: ui/main.qml:147
#, kde-format
msgctxt "@label 'this' refers to the 'disable touchpad while typing' feature"
msgid "This can interfere with video games."
msgstr "Esto puede interferir con los videojuegos."

#: ui/main.qml:169
#, kde-format
msgctxt "@title:group"
msgid "Left and right buttons:"
msgstr "Botones izquierdo y derecho:"

#: ui/main.qml:170
#, kde-format
msgctxt "@option:check"
msgid "Swap (left-handed mode)"
msgstr "Intercambiar (modo para zurdos)"

#: ui/main.qml:185
#, kde-format
msgctxt "@option:check 'both' refers to the left and right buttons'"
msgid "Press both simultaneously to middle-click"
msgstr "Pulsar ambos simultáneamente para clic central"

#: ui/main.qml:197
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"Activating this setting increases click latency by 50ms. The extra delay is "
"needed to correctly detect simultaneous left and right button presses."
msgstr ""
"La activación de este ajuste aumenta la latencia del clic en 50 ms. Este "
"retardo adicional es necesario para detectar correctamente la pulsación "
"simultánea de los botones derecho e izquierdo."

#: ui/main.qml:207
#, kde-format
msgctxt "@label:slider and @label:spinbox"
msgid "Pointer speed:"
msgstr "Velocidad del puntero:"

#: ui/main.qml:287
#, kde-format
msgctxt "@option:check"
msgid "Enable pointer acceleration"
msgstr "Activar aceleración del puntero"

#: ui/main.qml:299
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"When enabled, pointer travel distance increases with faster movement speed."
msgstr ""
"Cuando está activada, la distancia que recorre el puntero aumenta con más "
"velocidad."

#: ui/main.qml:309
#, kde-format
msgctxt "@label:slider"
msgid "Scrolling speed:"
msgstr "Velocidad de desplazamiento:"

#: ui/main.qml:360
#, kde-format
msgctxt "@item:inrange Slower Scroll"
msgid "Slower"
msgstr "Más lenta"

#: ui/main.qml:367
#, kde-format
msgctxt "@item:inrange Faster Scroll Speed"
msgid "Faster"
msgstr "Más rápida"

#: ui/main.qml:374
#, kde-format
msgctxt ""
"@title group begins the sentence 'Scroll by moving two fingers anywhere/"
"moving one finger on edge'"
msgid "Scroll by:"
msgstr "Desplazar:"

#: ui/main.qml:377
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'Scroll by moving two fingers anywhere'"
msgid "Moving two fingers anywhere"
msgstr "Al mover dos dedos a cualquier lugar"

#: ui/main.qml:395
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'Scroll by moving one finger on edge'"
msgid "Moving one finger on edge"
msgstr "Al mover un dedo sobre el borde"

#: ui/main.qml:404
#, kde-format
msgctxt "@option:check"
msgid "Invert scroll direction (Natural scrolling)"
msgstr "Invertir la dirección del desplazamiento (desplazamiento natural)"

#: ui/main.qml:421
#, kde-format
msgctxt "@option:check"
msgid "Disable horizontal scrolling"
msgstr "Desactivar el desplazamiento horizontal"

#: ui/main.qml:439
#, kde-format
msgctxt ""
"@title:group for radiobutton group, begins the sentence 'right-click by "
"pressing bottom-right corner/pressing with two fingers'"
msgid "Right-click by:"
msgstr "Clic derecho:"

#: ui/main.qml:443
#, kde-format
msgctxt ""
"@option:radio Completes the sentence 'right-click by pressing bottom-right "
"corner'"
msgid "Pressing bottom-right corner"
msgstr "Al pulsar la esquina inferior derecha"

#: ui/main.qml:448
#, kde-format
msgctxt "@info:usagetip shown below radio button"
msgid "Middle-click by pressing both bottom corners."
msgstr "Clic central al pulsar ambas esquinas inferiores."

#: ui/main.qml:449
#, kde-format
msgctxt "@info:usagetip shown below radio button"
msgid "Middle-click by pressing bottom center."
msgstr "Clic central al pulsar el centro de la zona inferior."

#: ui/main.qml:471
#, kde-format
msgctxt ""
"@option:radio Completes the sentence 'right-click by pressing with two "
"fingers'"
msgid "Pressing anywhere with two fingers"
msgstr "Al pulsar con dos dedos en cualquier lugar"

#: ui/main.qml:472
#, kde-format
msgctxt "@info shown below radio button"
msgid "Middle-click by pressing anywhere with three fingers."
msgstr "Clic central al pulsar con tres dedos en cualquier lugar."

#: ui/main.qml:484
#, kde-format
msgctxt ""
"@label for radiobutton group, begins the sentence 'middle-click by pressing "
"bottom-middle edge/by pressing anywhere with three fingers'"
msgid "Middle-click by:"
msgstr "Clic central:"

#: ui/main.qml:487
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'middle-click by pressing bottom-middle "
"edge'"
msgid "Pressing bottom-middle edge"
msgstr "Al pulsar el centro del borde inferior"

#: ui/main.qml:507
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'middle-click by pressing bottom-left "
"and bottom-right corners'"
msgid "Pressing bottom-left and bottom-right corners"
msgstr "Al pulsar las esquinas inferior derecha e inferior izquierda"

#: ui/main.qml:519
#, kde-format
msgctxt ""
"@option:check completes the sentence 'middle-click by pressing anywhere with "
"three fingers'"
msgid "Pressing anywhere with three fingers"
msgstr "Al pulsar con tres dedos en cualquier lugar"

#: ui/main.qml:532
#, kde-format
msgctxt "@label for checkbox, tap-to-click"
msgid "Tapping:"
msgstr "Toques:"

#: ui/main.qml:533
#, kde-format
msgctxt "@option:check"
msgid "Tap to click"
msgstr "Tocar para hacer clic"

#: ui/main.qml:548
#, kde-format
msgctxt "@option:check"
msgid "Allow dragging after tapping"
msgstr "Permitir arrastrar tras tocar"

#: ui/main.qml:560
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"Tap, then tap and immediately slide finger over the touchpad to drag. Lift "
"finger to drop."
msgstr ""
"Toque, vuelva a tocar e, inmediatamente, deslice el dedo sobre el panel "
"táctil para arrastrar. Levante el dedo para soltar."

#: ui/main.qml:567
#, kde-format
msgctxt "@option:check"
msgid "Allow briefly lifting finger during tap-and-drag"
msgstr "Permitir levantar el dedo brevemente durante tocar y arrastrar"

#: ui/main.qml:580
#, kde-format
msgctxt "@title:group"
msgid "Two-finger tap:"
msgstr "Toque con dos dedos:"

#: ui/main.qml:586
#, kde-format
msgctxt "@option:radio"
msgid "Right-click (three-finger tap to middle-click)"
msgstr "Clic derecho (toque con tres dedos para un clic central)"

#: ui/main.qml:587
#, kde-format
msgctxt "@option:radio"
msgid "Right-click"
msgstr "Clic derecho"

#: ui/main.qml:608
#, kde-format
msgctxt "@option:radio"
msgid "Middle-click (three-finger tap to right-click)"
msgstr "Clic central (toque con tres dedos para hacer un clic derecho)."

#: ui/main.qml:609
#, kde-format
msgctxt "@option:radio"
msgid "Middle-click"
msgstr "Clic central"
