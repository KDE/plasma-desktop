#: ui/main.qml:53
#, kde-format
msgctxt "@label:textbox"
msgid "Desktop folder:"
msgstr "Fillteán deisce:"

#: ui/main.qml:59
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder contains all the files you see on your desktop."
msgstr "Tá na comhaid go léir a fheiceann tú ar do dheasc sa fhillteán seo."

#: ui/main.qml:67
#, kde-format
msgctxt "@label:textbox"
msgid "Documents folder:"
msgstr "Fillteán na ndoiciméad:"

#: ui/main.qml:73
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder will be used by default to open or save documents."
msgstr ""
"Úsáidfear an fillteán seo de réir réamhshocraithe chun doiciméid a oscailt "
"nó a shábháil."

#: ui/main.qml:81
#, kde-format
msgctxt "@label:textbox"
msgid "Downloads folder:"
msgstr "Fillteán íoslódálacha:"

#: ui/main.qml:87
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder will be used by default to save your downloaded items."
msgstr ""
"Úsáidfear an fillteán seo de réir réamhshocraithe chun do mhíreanna "
"íoslódáilte a shábháil."

#: ui/main.qml:95
#, kde-format
msgctxt "@label:textbox"
msgid "Videos folder:"
msgstr "Fillteán físeáin:"

#: ui/main.qml:101
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder will be used by default to open or save video files."
msgstr ""
"Úsáidfear an fillteán seo de réir réamhshocraithe chun comhaid físe a "
"oscailt nó a shábháil."

#: ui/main.qml:109
#, kde-format
msgctxt "@label:textbox"
msgid "Pictures folder:"
msgstr "Fillteán pictiúr:"

#: ui/main.qml:115
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder will be used by default to open or save image files."
msgstr ""
"Úsáidfear an fillteán seo de réir réamhshocraithe chun comhaid íomhá a "
"oscailt nó a shábháil."

#: ui/main.qml:123
#, kde-format
msgctxt "@label:textbox"
msgid "Music folder:"
msgstr "Fillteán ceoil:"

#: ui/main.qml:129
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder will be used by default to open or save music files."
msgstr ""
"Úsáidfear an fillteán seo de réir réamhshocraithe chun comhaid cheoil a "
"oscailt nó a shábháil."

#: ui/main.qml:137
#, kde-format
msgctxt "@label:textbox"
msgid "Public folder:"
msgstr "Fillteán poiblí:"

#: ui/main.qml:143
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid ""
"This folder will be used by default for publicly-shared files when network "
"sharing is enabled."
msgstr ""
"Úsáidfear an fillteán seo de réir réamhshocraithe le haghaidh comhad a "
"roinntear go poiblí nuair a bheidh comhroinnt líonra cumasaithe."

#: ui/main.qml:151
#, kde-format
msgctxt "@label:textbox"
msgid "Templates folder:"
msgstr "Fillteán teimpléid:"

#: ui/main.qml:157
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder will be used by default to open or save file templates."
msgstr ""
"Úsáidfear an fillteán seo de réir réamhshocraithe chun teimpléid comhad a "
"oscailt nó a shábháil."

