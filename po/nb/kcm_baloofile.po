#: ui/main.qml:44
#, kde-format
msgctxt "@action:button"
msgid "Pause Indexer"
msgstr "Pause indeksering"

#: ui/main.qml:44
#, kde-format
msgctxt "@action:button"
msgid "Resume Indexer"
msgstr "Fortsett indeksering"

#: ui/main.qml:61
#, kde-format
msgctxt "@info inlinemessage"
msgid ""
"This will disable file searching in KRunner and launcher menus, and remove "
"extended metadata display from all KDE applications."
msgstr ""
"Filsøk i KRunner og programstartere slås av, og detaljert metadatavisning i "
"KDE-program fjernes."

#: ui/main.qml:71
#, kde-format
msgctxt "@info:inlinemessage"
msgid ""
"Do you want to delete the saved index data? %1 of space will be freed, but "
"if indexing is re-enabled later, the entire index will have to be re-created "
"from scratch. This may take some time, depending on the number of files to "
"index."
msgstr ""
"Vil du slette lagret indeksdata? %1 frigjøres på disken, men hvis du slår på "
"indekseringen senere, må hele indeksen bygges på nytt. Dette kan ta lang tid "
"avhengig av antall filer som må indekseres."

#: ui/main.qml:73
#, kde-format
msgctxt "@action:button"
msgid "Delete Index Data"
msgstr "Slett indeksdata"

#: ui/main.qml:91
#, kde-format
msgctxt "@info:usagetip"
msgid ""
"File Search helps you quickly locate your files. You can choose which "
"folders and what types of file data are indexed."
msgstr ""
"Filsøk hjelper deg å raskt finne filer basert på hva de inneholder. Du kan "
"velge hvilke mapper og filtyper som skal indekseres."

#: ui/main.qml:108
#, kde-format
msgctxt "@title:group"
msgid "Data to index:"
msgstr "Data som skal indekseres:"

#: ui/main.qml:109
#, kde-format
msgctxt "@option:radio Data to index"
msgid "Nothing (disable indexing entirely)"
msgstr "Ingenting (slå av indeksering fullstendig)"

#: ui/main.qml:121
#, kde-format
msgctxt "@option:radio Data to index"
msgid "File names only"
msgstr "Bare filnavn"

#: ui/main.qml:136
#, kde-format
msgctxt "@option:radio Data to index"
msgid "File names and contents"
msgstr "Filnavn og filinnhold"

#: ui/main.qml:157
#, kde-format
msgctxt "@option:check"
msgid "Also index hidden files and folders"
msgstr "Indekser også skjulte filer og mapper"

#: ui/main.qml:183
#, kde-format
msgctxt "@title:table Locations to include or exclude from indexing"
msgid "Locations"
msgstr "Adresser"

#: ui/main.qml:186
#, kde-format
msgctxt "@action:button"
msgid "Start Indexing a Folder…"
msgstr "Start indeksering av mapper …"

#: ui/main.qml:194
#, kde-format
msgctxt "@action:button"
msgid "Stop Indexing a Folder…"
msgstr "Stopp indeksering av mapper …"

#: ui/main.qml:212
#, kde-format
msgctxt "State and a percentage of progress"
msgid "%1, %2% complete"
msgstr "%1, %2 % fullført"

#: ui/main.qml:219
#, kde-kuit-format
msgctxt "@info Currently Indexing"
msgid "Currently indexing: <filename>%1</filename>"
msgstr "Indekserer nå: <filename>%1</filename>"

#: ui/main.qml:270
#, kde-format
msgctxt "@info:status"
msgid "Not indexed"
msgstr "Ikke indeksert"

#: ui/main.qml:271
#, kde-format
msgctxt "@info:status"
msgid "Indexed"
msgstr "Indeksert"

#: ui/main.qml:297
#, kde-format
msgctxt "Remove the list item for this filesystem path"
msgid "Remove entry"
msgstr "Fjern oppføring"

#: ui/main.qml:318
#, kde-format
msgctxt "@title:window"
msgid "Select a folder to include"
msgstr "Velg mappe å inkludere"

#: ui/main.qml:318
#, kde-format
msgctxt "@title:window"
msgid "Select a folder to exclude"
msgstr "Velg mappe å ekskludere"
