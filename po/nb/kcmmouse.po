#: backends/kwin_wl/kwin_wl_backend.cpp:61
#, kde-format
msgid "Querying input devices failed. Please reopen this settings module."
msgstr ""
"Feil ved søk etter innenheter. Prøv og åpne denne innstillingsmodulen på "
"nytt."

#: backends/kwin_wl/kwin_wl_backend.cpp:81
#, kde-format
msgid "Critical error on reading fundamental device infos of %1."
msgstr "Kritisk feil ved lesing av fundamentale enhetsinfo for %1."

#: kcm.cpp:86
#, kde-format
msgid "Not able to select appropriate backend"
msgstr "Klarte ikke velge egnet bakgrunnsmotor."

#: kcm.cpp:142
#, kde-format
msgid ""
"Error while loading values. See logs for more information. Please restart "
"this configuration module."
msgstr ""
"Feil ved innlesing av data. Se loggen for mer informasjon. Prøv å starte "
"oppsettsmodulen på nytt og prøv igjen."

#: kcm.cpp:145
#, kde-format
msgid "No pointer device found. Connect now."
msgstr "Fant ingen pekerenheter. Prøv å koble til en enhet nå."

#: kcm.cpp:154
#, kde-format
msgid ""
"Not able to save all changes. See logs for more information. Please restart "
"this configuration module and try again."
msgstr ""
"Klarte ikke lagre alle endringene. Se loggen for mer informasjon. Prøv å "
"starte oppsettsmodulen på nytt og prøv igjen."

#: kcm.cpp:172
#, kde-format
msgid ""
"Error while loading default values. Failed to set some options to their "
"default values."
msgstr ""
"Klarte ikke laste standardverdiene. Noen av verdiene kunne ikke settes til "
"standardverdier."

#: kcm.cpp:187
#, kde-format
msgid ""
"Error while adding newly connected device. Please reconnect it and restart "
"this configuration module."
msgstr ""
"Klarte ikke legge til nylig tilkoblet enhet. Prøv og koble den til en gang "
"til, og start så oppsettsmodulen på nytt."

#: kcm.cpp:200
#, kde-format
msgid "Pointer device disconnected. Closed its setting dialog."
msgstr "Pekerenheten er koblet fra, og innstillingsvinduet blir derfor lukket."

#: kcm.cpp:202
#, kde-format
msgid "Pointer device disconnected. No other devices found."
msgstr "Pekerenheten er koblet fra. Fant ingen andre enheter."

#: ui/bindings.qml:27
#, kde-format
msgctxt "@title"
msgid "Extra Mouse Buttons"
msgstr "Ekstra museknapper"

#: ui/bindings.qml:77
#, kde-format
msgctxt "@label for assigning an action to a numbered button"
msgid "Extra Button %1:"
msgstr "Ekstraknapp %1:"

#: ui/bindings.qml:106
#, kde-format
msgctxt "@action:button"
msgid "Press the mouse button for which you want to add a key binding"
msgstr "Trykk på museknappen som du vil knytte en handling til"

#: ui/bindings.qml:108
#, kde-format
msgctxt "@action:button, %1 is the translation of 'Extra Button %1' from above"
msgid "Enter the new key combination for %1"
msgstr "Trykk på ny hurtigtast for %1"

#: ui/bindings.qml:112
#, kde-format
msgctxt "@action:button"
msgid "Cancel"
msgstr "Avbryt"

#: ui/bindings.qml:130
#, kde-format
msgctxt "@action:button"
msgid "Press a mouse button"
msgstr "Trykk på en museknapp"

#: ui/bindings.qml:131
#, kde-format
msgctxt "@action:button, Bind a mousebutton to keyboard key(s)"
msgid "Add Binding…"
msgstr "Legg til binding …"

#: ui/main.qml:37
#, kde-format
msgctxt "@action:button"
msgid "Configure Extra Buttons…"
msgstr "Sett opp ekstraknapper …"

#: ui/main.qml:64
#, kde-format
msgctxt "@title:listbox select device"
msgid "Device:"
msgstr "Enhet:"

#: ui/main.qml:87
#, kde-format
msgctxt "@title:group"
msgid "General:"
msgstr "Generelt:"

#: ui/main.qml:88
#, kde-format
msgctxt "@option:check enable this mouse device"
msgid "Enable device"
msgstr "Bruk enhet"

#: ui/main.qml:105
#, kde-format
msgctxt "@title:group"
msgid "Left and right buttons:"
msgstr "Venstre og høyre knapp."

#: ui/main.qml:106
#, kde-format
msgctxt "@option:check Left and right buttons"
msgid "Swap (left-handed mode)"
msgstr "Bytt (venstrehåndsmodus)"

#: ui/main.qml:121
#, kde-format
msgctxt "@option:check 'both' refers to the left and right buttons'"
msgid "Press both simultaneously to middle-click"
msgstr "Trykk begge samtidig for å midtklikke"

#: ui/main.qml:133
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"Activating this setting increases click latency by 50ms. The extra delay is "
"needed to correctly detect simultaneous left and right button presses."
msgstr ""
"Hvis du slår på denne funksjonen, blir alle museklikkene forsinket med 50 "
"ms. Denne forsinkelsen trengs for å kunne oppdage «samtidige» venstre- og "
"høyreklikk."

#: ui/main.qml:148
#, kde-format
msgctxt "@label:slider and @label:spinbox"
msgid "Pointer speed:"
msgstr "Pekerhastighet:"

#: ui/main.qml:227
#, kde-format
msgctxt "@option:check"
msgid "Enable pointer acceleration"
msgstr "Slå på pekerakselerasjon"

#: ui/main.qml:241
#, kde-format
msgctxt "@info:whatsthis ContextualHelpButton tooltip"
msgid ""
"When enabled, pointer travel distance increases with faster movement speed."
msgstr ""
"Når dette er slått på, vil pekerekkevidden øke med raskere musebevegelser."

#: ui/main.qml:254
#, kde-format
msgctxt "@label:slider and @label:spinbox"
msgid "Scrolling speed:"
msgstr "Rullehastighet:"

#: ui/main.qml:304
#, kde-format
msgctxt "Slower Scroll"
msgid "Slower"
msgstr "Saktere"

#: ui/main.qml:313
#, kde-format
msgctxt "Faster Scroll Speed"
msgid "Faster"
msgstr "Raskere"

#: ui/main.qml:321
#, kde-format
msgctxt "@title:group"
msgid "Scrolling:"
msgstr "Rulling:"

#: ui/main.qml:322
#, kde-format
msgctxt "@option:check"
msgid "Invert scroll direction"
msgstr "Snu om på rulleretning"

#: ui/main.qml:339
#, kde-format
msgctxt "@option:check"
msgid "Hold down middle button and move mouse to scroll"
msgstr "Trykk på midtknappen og flytt musa for å rulle"

#: ui/main.qml:351
#, kde-format
msgctxt "@info:whatsthis ContextualHelpButton tooltip"
msgid ""
"This will interfere with applications that use middle-button drag, such as "
"some image editors, document viewers, or video games. It may be used on any "
"device, but is intended primarily as a substitute for scroll wheels on "
"devices that do not have any."
msgstr ""
"Dette vil forstyrre programmer som benytter dra med midtknapp, for eksempel "
"noen bilderedigeringsprogram, dokumentvisere eller dataspill. Funksjonen kan "
"brukes på alle enheter, men er primært tiltenkt som erstatning for rullehjul "
"på enheter som mangler dette."
