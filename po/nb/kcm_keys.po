#: kcm_keys.cpp:366
#, kde-kuit-format
msgctxt ""
"@info %2 is the name of a category inside the 'Common Actions' section"
msgid ""
"Shortcut <shortcut>%1</shortcut> is already assigned to the common %2 action "
"<interface>%3</interface>.<nl/><nl/>Re-assign it to %4?"
msgstr ""
"Hurtigtasten <shortcut>%1</shortcut> er allerede tildelt den vanlige «%2»-"
"handlinga <interface>%3</interface>.<nl/> <nl/> Vil du tildele den på nytt "
"til %4?"

#: kcm_keys.cpp:372
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Shortcut <shortcut>%1</shortcut> is already assigned to action <interface>"
"%2</interface> of <application>%3</application>.<nl/><nl/>Reassign it to "
"action <interface>%4</interface> of <application>%5</application>?"
msgstr ""
"Hurtigtasten <shortcut>%1</shortcut> er allerede tildelt <application>%3</"
"application>-handlinga <interface>%2</interface>.<nl/> <nl/> Vil du tildele "
"den på nytt til <application>%5</application>-handlinga <interface>%4</"
"interface>?"

