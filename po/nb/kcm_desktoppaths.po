#: ui/main.qml:53
#, kde-format
msgctxt "@label:textbox"
msgid "Desktop folder:"
msgstr "Skrivebordsmappe:"

#: ui/main.qml:59
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder contains all the files you see on your desktop."
msgstr "Denne mappen inneholder alle filene som du ser på skrivebordet."

