"@item:inlistbox what to show for active application in horizontal panel"
msgid "Name"
msgstr "Namn"

#: ConfigGeneral.qml:91
#, kde-format
msgctxt "@info:usagetip display mode for active application"
msgid "Only icons can be shown when the Panel is vertical."
msgstr "Berre ikon kan visast når panelet er loddrett."

#: ConfigGeneral.qml:93
#, kde-format
msgctxt "@info:usagetip display mode for active application"
msgid "Not applicable when the widget is on the Desktop."
msgstr "Ikkje aktuell når skjermelementet er plassert på skrivebordet."

#: ConfigGeneral.qml:106
#, kde-format
msgctxt "@label:checkbox"
msgid "Open on hover:"
msgstr "Opna når peikaren er over:"

