#: config.qml:13
#, kde-format
msgctxt "@title:group for configuration dialog page"
msgid "General"
msgstr "Generelt"

#: ConfigGeneral.qml:37
#, kde-format
msgctxt "@label:listbox"
msgid "For active application, show:"
msgstr "Vis for gjeldande program:"

#: ConfigGeneral.qml:42
#, kde-format
msgctxt ""
"@item:inlistbox what to show for active application in horizontal panel"
msgid "Icon and name"
