#, kde-format
msgctxt "@option:check open-on-hover is enabled, with the following delay:"
msgid "Enabled, with delay:"
msgstr "Slått på, med forseinking:"

#: ConfigGeneral.qml:124
#, kde-format
msgctxt "@item:valuesuffix, %1 is hover activation delay in ms"
msgid "%1 ms"
msgid_plural "%1 ms"
msgstr[0] "%1 ms"
msgstr[1] "%1 ms"

#: ConfigGeneral.qml:133
#, kde-format
msgctxt "short for millisecond(s)"
msgid "ms"
msgid_plural "ms"
msgstr[0] "ms"
msgstr[1] "ms"

#: ConfigGeneral.qml:136
#, kde-format
msgctxt "@label:spinbox accessible %1 is milliseconds"
msgid "Hover open delay %1 ms"
msgstr "Forseinking før opning %1 ms"

#: ConfigGeneral.qml:146
#, kde-format
msgctxt ""
"@label for checkbox group, completes sentence like: … from current screen"
