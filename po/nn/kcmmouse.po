#: inputbackend.cpp:49
#, kde-format
msgid "Critical error on reading fundamental device infos of %1."
msgstr "Kritisk feil ved lesing av fundamental einingsinfo for %1."

#: kcm.cpp:112
#, kde-format
msgid ""
"Error while loading values. See logs for more information. Please restart "
"this configuration module."
msgstr ""
"Feil ved innlesing av data. Sjå loggen for meir informasjon, og prøv å "
"starta oppsettmodulen på nytt."

#: kcm.cpp:115
#, kde-format
msgid "No pointer device found. Connect now."
msgstr "Fann inga peikareining. Prøv å kopla til ei eining no."

#: kcm.cpp:124
#, kde-format
msgid ""
"Not able to save all changes. See logs for more information. Please restart "
"this configuration module and try again."
msgstr ""
"Klarte ikkje lagra alle endringane. Sjå loggen for meir informasjon. Prøv å "
"starta oppsettmodulen på nytt og prøv igjen."

#: kcm.cpp:142
#, kde-format
msgid ""
"Error while loading default values. Failed to set some options to their "
"default values."
msgstr ""
"Klarte ikkje lasta standardverdiane. Nokre av verdiane kunne ikkje setjast "
"til standardverdiar."

#: kcm.cpp:157
#, kde-format
msgid ""
"Error while adding newly connected device. Please reconnect it and restart "
"this configuration module."
msgstr ""
"Klarte ikkje leggja til nyleg tilkopla eining. Prøv å kopla ho til ein gong "
"til, og start så oppsettmodulen på nytt."

#: kcm.cpp:170
#, kde-format
msgid "Pointer device disconnected. Closed its setting dialog."
msgstr ""
"Peikareininga er kopla frå, og innstillingsvindauget vart derfor lukka."

#: kcm.cpp:172
#, kde-format
msgid "Pointer device disconnected. No other devices found."
msgstr "Peikareininga er kopla frå. Fann ingen andre einingar."

#: ui/bindings.qml:27
#, kde-format
msgctxt "@title"
msgid "Extra Mouse Buttons"
msgstr "Ekstra museknappar"

#: ui/bindings.qml:77
#, kde-format
msgctxt "@label for assigning an action to a numbered button"
msgid "Extra Button %1:"
msgstr "Ekstraknapp %1:"

#: ui/bindings.qml:106
#, kde-format
msgctxt "@action:button"
msgid "Press the mouse button for which you want to add a key binding"
msgstr "Trykk på museknappen som du vil knyta til ei handling"

#: ui/bindings.qml:108
#, kde-format
msgctxt "@action:button, %1 is the translation of 'Extra Button %1' from above"
msgid "Enter the new key combination for %1"
msgstr "Trykk ny snøggtast for %1"

#: ui/bindings.qml:112
#, kde-format
msgctxt "@action:button"
msgid "Cancel"
msgstr "Avbryt"

#: ui/bindings.qml:130
#, kde-format
msgctxt "@action:button"
msgid "Press a mouse button"
msgstr "Trykk på ein museknapp"

#: ui/bindings.qml:131
#, kde-format
msgctxt "@action:button, Bind a mousebutton to keyboard key(s)"
msgid "Add Binding…"
msgstr "Legg til binding …"

#: ui/main.qml:37
#, kde-format
msgctxt "@action:button"
msgid "Configure Extra Buttons…"
msgstr "Set opp ekstraknappar …"

#: ui/main.qml:64
#, kde-format
msgctxt "@title:listbox select device"
msgid "Device:"
msgstr "Eining:"

#: ui/main.qml:86
#, kde-format
msgctxt "@title:group"
msgid "General:"
msgstr "Generelt:"

#: ui/main.qml:87
#, kde-format
msgctxt "@option:check enable this mouse device"
msgid "Enable device"
msgstr "Bruk eining"

#: ui/main.qml:102
#, kde-format
msgctxt "@title:group"
msgid "Left and right buttons:"
msgstr "Venstre og høgre knapp:"

#: ui/main.qml:103
#, kde-format
msgctxt "@option:check Left and right buttons"
msgid "Swap (left-handed mode)"
msgstr "Byt (venstrehandsmodus)"

#: ui/main.qml:118
#, kde-format
msgctxt "@option:check 'both' refers to the left and right buttons'"
msgid "Press both simultaneously to middle-click"
msgstr "Trykk begge samtidig for å midtklikka"

#: ui/main.qml:130
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"Activating this setting increases click latency by 50ms. The extra delay is "
"needed to correctly detect simultaneous left and right button presses."
msgstr ""
"Viss du slår på denne funksjonen, vert alle museklikk forseinka med 50 ms. "
"Denne forseinkinga trengst for å kunna oppdaga «samtidige» venstre- og "
"høgreklikk."

#: ui/main.qml:142
#, kde-format
msgctxt "@label:slider and @label:spinbox"
msgid "Pointer speed:"
msgstr "Peikarfart:"

#: ui/main.qml:223
#, kde-format
msgctxt "@option:check"
msgid "Enable pointer acceleration"
msgstr "Bruk peikarakselerasjon"

#: ui/main.qml:235
#, kde-format
msgctxt "@info:whatsthis ContextualHelpButton tooltip"
msgid ""
"When enabled, pointer travel distance increases with faster movement speed."
msgstr ""
"Når dette er slått på, vil peikaren flytta seg lenger ved raskare rørsle."

#: ui/main.qml:245
#, kde-format
msgctxt "@label:slider and @label:spinbox"
msgid "Scrolling speed:"
msgstr "Rullefart:"

#: ui/main.qml:295
#, kde-format
msgctxt "Slower Scroll"
msgid "Slower"
msgstr "Saktare"

#: ui/main.qml:304
#, kde-format
msgctxt "Faster Scroll Speed"
msgid "Faster"
msgstr "Raskare"

#: ui/main.qml:314
#, kde-format
msgctxt "@title:group"
msgid "Scrolling:"
msgstr "Rulling:"

#: ui/main.qml:315
#, kde-format
msgctxt "@option:check"
msgid "Invert scroll direction"
msgstr "Omvend rulleretning"

#: ui/main.qml:330
#, kde-format
msgctxt "@option:check"
msgid "Hold down middle button and move mouse to scroll"
msgstr "Hald inne midtknappen og flytt musa for å rulla"

#: ui/main.qml:342
#, kde-format
msgctxt "@info:whatsthis ContextualHelpButton tooltip"
msgid ""
"This will interfere with applications that use middle-button drag, such as "
"some image editors, document viewers, or video games. It may be used on any "
"device, but is intended primarily as a substitute for scroll wheels on "
"devices that do not have any."
msgstr ""
"Dette fungerer ikkje skikkeleg med program som brukar midtknap-draging, for "
"eksempel nokre biletredigerings­program, dokument­visarar og dataspel. "
"Funksjonen kan brukast på alle einingar, men er hovudsakleg meint som "
"erstatning for rullehjul på einingar som manglar dette."

#~ msgid "Not able to select appropriate backend"
#~ msgstr "Klarar ikkje velja eigna motor."
