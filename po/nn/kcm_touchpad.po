#: backends/kwin_wayland/kwinwaylandbackend.cpp:46
#, kde-format
msgid "Critical error on reading fundamental device infos for touchpad %1."
msgstr "Kritisk feil ved lesing av fundamental einingsinfo for styreplata %1."

#: backends/x11/xlibbackend.cpp:69
#, kde-format
msgid "Cannot connect to X server"
msgstr "Klarte ikkje kopla til X-tenaren"

#: backends/x11/xlibbackend.cpp:80
#, kde-format
msgid "No touchpad found"
msgstr "Fann inga styreplate"

#: backends/x11/xlibbackend.cpp:120
#, kde-format
msgid "Cannot apply touchpad configuration"
msgstr "Klarte ikkje ta i bruk styreplate-oppsettet"

#: backends/x11/xlibbackend.cpp:134
#, kde-format
msgid "Cannot read touchpad configuration"
msgstr "Klarte ikkje lesa styreplate-oppsettet"

#: backends/x11/xlibbackend.cpp:147
#, kde-format
msgid "Cannot read default touchpad configuration"
msgstr "Klarte ikkje lesa standard styreplate-oppsett"

#: kcm.cpp:69
#, kde-format
msgid "Not able to select appropriate backend"
msgstr ""

#: kcm.cpp:126
#, kde-format
msgid ""
"Error while loading values. See logs for more information. Please restart "
"this configuration module."
msgstr ""
"Feil ved innlesing av data. Sjå loggen for meir informasjon, og prøv å "
"starta oppsettmodulen på nytt."

#: kcm.cpp:129
#, fuzzy, kde-format
#| msgid "No touchpad found. Connect touchpad now."
msgid "No pointer device found. Connect now."
msgstr "Fann ikkje noka styreplate. Prøv å kopla ho til."

#: kcm.cpp:138
#, kde-format
msgid ""
"Not able to save all changes. See logs for more information. Please restart "
"this configuration module and try again."
msgstr ""
"Klarte ikkje lagra alle endringane. Sjå loggen for meir informasjon. Prøv å "
"starta oppsettmodulen på nytt og prøv igjen."

#: kcm.cpp:157
#, kde-format
msgid ""
"Error while loading default values. Failed to set some options to their "
"default values."
msgstr ""
"Klarte ikkje lasta standardverdiane. Nokre av verdiane kunne ikkje setjast "
"til standardverdiar."

#: kcm.cpp:172
#, kde-format
msgid ""
"Error while adding newly connected device. Please reconnect it and restart "
"this configuration module."
msgstr ""
"Klarte ikkje leggja til nyleg tilkopla eining. Prøv å kopla ho til ein gong "
"til, og start så oppsettmodulen på nytt."

#: kcm.cpp:185
#, fuzzy, kde-format
#| msgid "Touchpad disconnected. Closed its setting dialog."
msgid "Pointer device disconnected. Closed its setting dialog."
msgstr "Styreplata er kopla frå, og innstillingsvindauget vart derfor lukka."

#: kcm.cpp:187
#, fuzzy, kde-format
#| msgid "Touchpad disconnected. No other touchpads found."
msgid "Pointer device disconnected. No other devices found."
msgstr "Styreplata er kopla frå. Finn ingen andre styreplater."

#: ui/main.qml:69
#, kde-format
msgctxt "@info:status placeholdermessage text"
msgid "No touchpad found"
msgstr "Fann inga styreplate"

# Bør ha med artikkelen «ei» her for å gjera det (litt) klarare at det er snakk om imperativ (og at teksten altså ikkje tyder at ei styreplate *er* tilkopla). Jamfør og med tilsvarande tekst «Kopla til ein kabla/trådlaus spelkontrollar», som bør vera på same form.
#: ui/main.qml:70
#, kde-format
msgctxt "@info:usagetip placeholdermessage explanation"
msgid "Connect an external touchpad"
msgstr "Kopla til ei ekstern styreplate"

#: ui/main.qml:84
#, kde-format
msgctxt "@label:listbox device selection"
msgid "Device:"
msgstr "Eining:"

#: ui/main.qml:108
#, kde-format
msgctxt "@title:group prefix for checkbox group"
msgid "General:"
msgstr "Generelt:"

#: ui/main.qml:109
#, kde-format
msgctxt "@option:check"
msgid "Enable device"
msgstr "Bruk eining"

#: ui/main.qml:122
#, kde-format
msgctxt "@option:check"
msgid "Disable while mouse is connected"
msgstr "Slå av når musa er tilkopla"

#: ui/main.qml:143
#, kde-format
msgctxt "option:check"
msgid "Disable while typing"
msgstr "Slå av styreplata under tasting"

#: ui/main.qml:165
#, kde-format
msgctxt "@label 'this' refers to the 'disable touchpad while typing' feature"
msgid "This can interfere with video games."
msgstr "Dette kan øydeleggja for dataspel."

#: ui/main.qml:179
#, kde-format
msgctxt "@title:group"
msgid "Left and right buttons:"
msgstr "Venstre og høgre knapp:"

#: ui/main.qml:180
#, kde-format
msgctxt "@option:check"
msgid "Swap (left-handed mode)"
msgstr "Byt (venstrehandsmodus)"

#: ui/main.qml:195
#, kde-format
msgctxt "@option:check 'both' refers to the left and right buttons'"
msgid "Press both simultaneously to middle-click"
msgstr "Trykk begge samtidig for å midtklikka"

#: ui/main.qml:207
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"Activating this setting increases click latency by 50ms. The extra delay is "
"needed to correctly detect simultaneous left and right button presses."
msgstr ""
"Viss du slår på denne funksjonen, vert alle museklikk forseinka med 50 ms. "
"Denne forseinkinga trengst for å kunna oppdaga «samtidige» venstre- og "
"høgreklikk."

#: ui/main.qml:220
#, kde-format
msgctxt "@label:slider and @label:spinbox"
msgid "Pointer speed:"
msgstr "Peikarfart:"

#: ui/main.qml:299
#, kde-format
msgctxt "@option:check"
msgid "Enable pointer acceleration"
msgstr "Bruk peikarakselerasjon"

#: ui/main.qml:313
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"When enabled, pointer travel distance increases with faster movement speed."
msgstr ""
"Når dette er slått på, vil peikaren flytta seg lenger ved raskare rørsle."

#: ui/main.qml:326
#, kde-format
msgctxt "@label:slider"
msgid "Scrolling speed:"
msgstr "Rullefart:"

#: ui/main.qml:376
#, kde-format
msgctxt "@item:inrange Slower Scroll"
msgid "Slower"
msgstr "Saktare"

#: ui/main.qml:383
#, kde-format
msgctxt "@item:inrange Faster Scroll Speed"
msgid "Faster"
msgstr "Raskare"

#: ui/main.qml:390
#, kde-format
msgctxt ""
"@title group begins the sentence 'Scroll by moving two fingers anywhere/"
"moving one finger on edge'"
msgid "Scroll by:"
msgstr "Rull med:"

#: ui/main.qml:408
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'Scroll by moving two fingers anywhere'"
msgid "Moving two fingers anywhere"
msgstr "Flytting av to fingrar kor som helst"

#: ui/main.qml:415
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'Scroll by moving one finger on edge'"
msgid "Moving one finger on edge"
msgstr "Flytting av éin finger langs kanten"

#: ui/main.qml:423
#, kde-format
msgctxt "@option:check"
msgid "Invert scroll direction (Natural scrolling)"
msgstr "Omvend rulleretning  (naturleg rulling)"

#: ui/main.qml:436
#, kde-format
msgctxt "@option:check"
msgid "Disable horizontal scrolling"
msgstr "Slå av vassrett rulling"

#: ui/main.qml:457
#, kde-format
msgctxt ""
"@title:group for radiobutton group, begins the sentence 'right-click by "
"pressing bottom-right corner/pressing with two fingers'"
msgid "Right-click by:"
msgstr "Høgreklikk med:"

#: ui/main.qml:477
#, kde-format
msgctxt ""
"@option:radio Completes the sentence 'right-click by pressing bottom-right "
"corner'"
msgid "Pressing bottom-right corner"
msgstr "Trykk i hjørnet nede til høgre"

#: ui/main.qml:492
#, kde-format
msgctxt "@info:usagetip shown below radio button"
msgid "Middle-click by pressing both bottom corners."
msgstr "Midtklikk ved å trykkja i begge nedre hjørne."

#: ui/main.qml:493
#, kde-format
msgctxt "@info:usagetip shown below radio button"
msgid "Middle-click by pressing bottom center."
msgstr "Midtklikk ved å trykkja i midten nede."

#: ui/main.qml:501
#, kde-format
msgctxt ""
"@option:radio Completes the sentence 'right-click by pressing with two "
"fingers'"
msgid "Pressing anywhere with two fingers"
msgstr "Trykk med to fingrar kor som helst"

#: ui/main.qml:516
#, kde-format
msgctxt "@info shown below radio button"
msgid "Middle-click by pressing anywhere with three fingers."
msgstr "Midtlikk ved å trykkja med tre fingrar kor som helst."

#: ui/main.qml:525
#, kde-format
msgctxt ""
"@label for radiobutton group, begins the sentence 'middle-click by pressing "
"bottom-middle edge/by pressing anywhere with three fingers'"
msgid "Middle-click by:"
msgstr "Midtklikk med:"

#: ui/main.qml:545
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'middle-click by pressing bottom-middle "
"edge'"
msgid "Pressing bottom-middle edge"
msgstr "Trykk på midten av nedre kant"

#: ui/main.qml:552
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'middle-click by pressing bottom-left "
"and bottom-right corners'"
msgid "Pressing bottom-left and bottom-right corners"
msgstr "Trykk i nedre venstre og høgre hjørne"

#: ui/main.qml:559
#, kde-format
msgctxt ""
"@option:check completes the sentence 'middle-click by pressing anywhere with "
"three fingers'"
msgid "Pressing anywhere with three fingers"
msgstr "Trykk med tre fingrar kor som helst"

#: ui/main.qml:575
#, kde-format
msgctxt "@label for checkbox, tap-to-click"
msgid "Tapping:"
msgstr "Tapping:"

#: ui/main.qml:576
#, kde-format
msgctxt "@option:check"
msgid "Tap to click"
msgstr "Tapp for å klikka"

#: ui/main.qml:591
#, kde-format
msgctxt "@option:check"
msgid "Allow dragging after tapping"
msgstr "Tillat draging etter tapping"

#: ui/main.qml:603
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"Tap, then tap and immediately slide finger over the touchpad to drag. Lift "
"finger to drop."
msgstr ""
"Dra ved å tappa og straks tappa på nytt medan du dreg fingeren over "
"styreplata. Løft fingeren for å sleppa."

#: ui/main.qml:609
#, kde-format
msgctxt "@option:check"
msgid "Allow briefly lifting finger during tap-and-drag"
msgstr "Tillatt kort løft av fingeren ved tapp-og-slepp-rørsle"

#: ui/main.qml:622
#, kde-format
msgctxt "@title:group"
msgid "Two-finger tap:"
msgstr "Tofingertrykk:"

#: ui/main.qml:641
#, kde-format
msgctxt "@option:radio"
msgid "Right-click (three-finger tap to middle-click)"
msgstr "Høgreklikk (trefingertrykk for midtklikk)"

#: ui/main.qml:642
#, kde-format
msgctxt "@option:radio"
msgid "Right-click"
msgstr "Høgreklikk"

#: ui/main.qml:650
#, kde-format
msgctxt "@option:radio"
msgid "Middle-click (three-finger tap to right-click)"
msgstr "Midtklikk (trefingertrykk for høgreklikk)"

#: ui/main.qml:651
#, kde-format
msgctxt "@option:radio"
msgid "Middle-click"
msgstr "Midtklikk"
