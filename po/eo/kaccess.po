#~ "malpremado."

#~ msgid "Sticky keys has been disabled."
#~ msgstr "Fiksaj klavoj malaktiviĝis."

#~ msgid ""
#~ "Mouse keys has been enabled. From now on, you can use the number pad of "
#~ "your keyboard in order to control the mouse."
