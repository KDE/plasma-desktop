#~ "Malrapidaj klavoj aktiviĝis. Ekde nun, vi bezonas premi ĉiun klavon dum "
#~ "certa tempo antaŭ ol ĝi akceptitas."

#~ msgid "Slow keys has been disabled."
#~ msgstr "Malrapidaj klavoj malaktiviĝis."

#~ msgid ""
#~ "Bounce keys has been enabled. From now on, each key will be blocked for a "
#~ "certain length of time after it was used."
