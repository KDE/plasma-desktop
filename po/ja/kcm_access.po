msgid "Use number pad to move pointer:"
msgstr "テンキーでポインタを移動する:"

#: ui/MouseNavigation.qml:22
#, kde-format
msgctxt "@option:check Enable mouse navigation"
msgid "Enable"
msgstr "有効"

#: ui/MouseNavigation.qml:33
#, kde-kuit-format
msgctxt "@info:tooltip"
msgid ""
"The numpad key <shortcut>5</shortcut> functions as a mouse click, toggled by "
"<shortcut>/</shortcut> for middle click, <shortcut>*</shortcut> for right "
"click and <shortcut>NumLock</shortcut> for left click. The keys <shortcut>2</"
"shortcut>, <shortcut>4</shortcut>, <shortcut>6</shortcut>, and <shortcut>8</"
"shortcut> allow for cardinal movement (down, left, right, and up). The keys "
"<shortcut>1</shortcut>, <shortcut>3</shortcut>, <shortcut>7</shortcut>, and "
"<shortcut>9</shortcut> allow for diagonal movement."
msgstr ""
"テンキーの <shortcut>5</shortcut> はクリックとして機能し、<shortcut>/</"
"shortcut> で中クリック、<shortcut>*</shortcut> で右クリック、"
"<shortcut>NumLock</shortcut> で左クリックに切り替えられます。<shortcut>2</"
"shortcut>, <shortcut>4</shortcut>, <shortcut>6</shortcut>, <shortcut>8</"
"shortcut> は上下左右の移動、<shortcut>1</shortcut>, <shortcut>3</shortcut>, "
"<shortcut>7</shortcut>, <shortcut>9</shortcut> は斜め方向の移動に使用します。"

