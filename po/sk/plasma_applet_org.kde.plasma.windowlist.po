#: ConfigGeneral.qml:91
#, kde-format
msgctxt "@info:usagetip display mode for active application"
msgid "Only icons can be shown when the Panel is vertical."
msgstr "Keď je panel vertikálny, môžu sa zobrazovať len ikony."

