#: backends/kwin_wayland/kwinwaylandbackend.cpp:46
#, kde-format
msgid "Critical error on reading fundamental device infos for touchpad %1."
msgstr ""
"Při načítání základních informací o zařízení touchpadu %1 došlo ke kritické "
"chybě."

#: backends/x11/xlibbackend.cpp:69
#, kde-format
msgid "Cannot connect to X server"
msgstr "Nelze se připojit k  X serveru"

#: backends/x11/xlibbackend.cpp:80
#, kde-format
msgid "No touchpad found"
msgstr "Nebyl nalezen žádný touchpad"

#: backends/x11/xlibbackend.cpp:120
#, kde-format
msgid "Cannot apply touchpad configuration"
msgstr "Nelze použít nastavení touchpadu"

#: backends/x11/xlibbackend.cpp:134
#, kde-format
msgid "Cannot read touchpad configuration"
msgstr "Nelze přečíst nastavení touchpadu"

#: backends/x11/xlibbackend.cpp:147
#, kde-format
msgid "Cannot read default touchpad configuration"
msgstr "Výchozí konfiguraci touchpadu nelze načíst"

#: kcm.cpp:69
#, kde-format
msgid "Not able to select appropriate backend"
msgstr "Nelze vybrat vhodnou podpůrnou vrstvu"

#: kcm.cpp:126
#, kde-format
msgid ""
"Error while loading values. See logs for more information. Please restart "
"this configuration module."
msgstr ""
"Chyba při načítání hodnot.Více informací naleznete v záznamech činnosti. "
"Prosím restartujte tento nastavovací modul."

#: kcm.cpp:129
#, kde-format
msgid "No pointer device found. Connect now."
msgstr "Žádné ukazovací zařízení nebylo nalezeno. Připojte zařízení."

#: kcm.cpp:138
#, kde-format
msgid ""
"Not able to save all changes. See logs for more information. Please restart "
"this configuration module and try again."
msgstr ""
"Nebylo možné uložit všechny změny. Více informací naleznete v záznamu. "
"Restartujte tento konfigurační modul a zkuste to znovu."

#: kcm.cpp:157
#, kde-format
msgid ""
"Error while loading default values. Failed to set some options to their "
"default values."
msgstr ""
"Chyba při načítání výchozích hodnot. Nastavení některých voleb na výchozí "
"hodnotu selhalo."

#: kcm.cpp:172
#, kde-format
msgid ""
"Error while adding newly connected device. Please reconnect it and restart "
"this configuration module."
msgstr ""
"Při přidávání nově připojeného zařízení došlo k chybě. Připojte zařízení "
"znovu a restartujte tento konfigurační modul."

#: kcm.cpp:185
#, kde-format
msgid "Pointer device disconnected. Closed its setting dialog."
msgstr "Ukazovací zařízení bylo odpojeno. Zavřete dialogové okno nastavení."

#: kcm.cpp:187
#, kde-format
msgid "Pointer device disconnected. No other devices found."
msgstr ""
"Ukazovací zařízení bylo odpojeno. Žádná další zařízení nebyla nalezena."

#: ui/main.qml:69
#, kde-format
msgctxt "@info:status placeholdermessage text"
msgid "No touchpad found"
msgstr "Nebyl nalezen žádný touchpad"

#: ui/main.qml:70
#, kde-format
msgctxt "@info:usagetip placeholdermessage explanation"
msgid "Connect an external touchpad"
msgstr "Připojit externí touchpad"

#: ui/main.qml:87
#, kde-format
msgctxt "@label:listbox device selection"
msgid "Device:"
msgstr "Zařízení:"

#: ui/main.qml:110
#, kde-format
msgctxt "@title:group prefix for checkbox group"
msgid "General:"
msgstr "Obecné:"

#: ui/main.qml:111
#, kde-format
msgctxt "@option:check"
msgid "Enable device"
msgstr "Povolit zařízení"

#: ui/main.qml:126
#, kde-format
msgctxt "@option:check"
msgid "Disable while mouse is connected"
msgstr "Vypnout pokud je připojena myš"

#: ui/main.qml:146
#, kde-format
msgctxt "option:check"
msgid "Disable while typing"
msgstr "Zakázat při psaní"

#: ui/main.qml:147
#, kde-format
msgctxt "@label 'this' refers to the 'disable touchpad while typing' feature"
msgid "This can interfere with video games."
msgstr "Toto může mít dopad na počítačové hry."

#: ui/main.qml:169
#, kde-format
msgctxt "@title:group"
msgid "Left and right buttons:"
msgstr "Levá a pravá tlačítka:"

#: ui/main.qml:170
#, kde-format
msgctxt "@option:check"
msgid "Swap (left-handed mode)"
msgstr "Zaměnit (režim pro leváky)"

#: ui/main.qml:185
#, kde-format
msgctxt "@option:check 'both' refers to the left and right buttons'"
msgid "Press both simultaneously to middle-click"
msgstr "Stisknout obě současně pro kliknutí prostředním tlačítkem"

#: ui/main.qml:197
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"Activating this setting increases click latency by 50ms. The extra delay is "
"needed to correctly detect simultaneous left and right button presses."
msgstr ""
"Povolením tohoto nastavení zvýší zpoždění kliknutí myši o 50 ms. Toto "
"dodatečné zpoždění je potřeba pro správné rozpoznání souběžného kliknutí "
"levým a pravým tlačítkem myši."

#: ui/main.qml:207
#, kde-format
msgctxt "@label:slider and @label:spinbox"
msgid "Pointer speed:"
msgstr "Rychlost kurzoru:"

#: ui/main.qml:287
#, kde-format
msgctxt "@option:check"
msgid "Enable pointer acceleration"
msgstr "Povolit akceleraci kurzoru"

#: ui/main.qml:299
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"When enabled, pointer travel distance increases with faster movement speed."
msgstr ""
"Pokud povoleno, vzdálenost posunu kurzoru se zvyšuje s rostoucí rychlostí "
"pohybu myši."

#: ui/main.qml:309
#, kde-format
msgctxt "@label:slider"
msgid "Scrolling speed:"
msgstr "Rychlost rolování:"

#: ui/main.qml:360
#, kde-format
msgctxt "@item:inrange Slower Scroll"
msgid "Slower"
msgstr "Pomaleji"

#: ui/main.qml:367
#, kde-format
msgctxt "@item:inrange Faster Scroll Speed"
msgid "Faster"
msgstr "Rychleji"

#: ui/main.qml:374
#, kde-format
msgctxt ""
"@title group begins the sentence 'Scroll by moving two fingers anywhere/"
"moving one finger on edge'"
msgid "Scroll by:"
msgstr "Rolování:"

#: ui/main.qml:377
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'Scroll by moving two fingers anywhere'"
msgid "Moving two fingers anywhere"
msgstr "Pohyb dvěma prsty kdekoli"

#: ui/main.qml:395
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'Scroll by moving one finger on edge'"
msgid "Moving one finger on edge"
msgstr "Pohyb jedním prstem na okraji"

#: ui/main.qml:404
#, kde-format
msgctxt "@option:check"
msgid "Invert scroll direction (Natural scrolling)"
msgstr "Obrátit směr rolování (tzv. přirozený směr rolování)"

#: ui/main.qml:421
#, kde-format
msgctxt "@option:check"
msgid "Disable horizontal scrolling"
msgstr "Vypnout vodorovné rolování"

#: ui/main.qml:439
#, kde-format
msgctxt ""
"@title:group for radiobutton group, begins the sentence 'right-click by "
"pressing bottom-right corner/pressing with two fingers'"
msgid "Right-click by:"
msgstr "Kliknutí pravým tlačítkem myši"

#: ui/main.qml:443
#, kde-format
msgctxt ""
"@option:radio Completes the sentence 'right-click by pressing bottom-right "
"corner'"
msgid "Pressing bottom-right corner"
msgstr "Stisknutí pravého dolního rohu"

#: ui/main.qml:448
#, kde-format
msgctxt "@info:usagetip shown below radio button"
msgid "Middle-click by pressing both bottom corners."
msgstr "Prostřední tlačítko stisknutím obou dolních rohů."

#: ui/main.qml:449
#, kde-format
msgctxt "@info:usagetip shown below radio button"
msgid "Middle-click by pressing bottom center."
msgstr "Prostřední tlačítko stisknutím na střed dole."

#: ui/main.qml:471
#, kde-format
msgctxt ""
"@option:radio Completes the sentence 'right-click by pressing with two "
"fingers'"
msgid "Pressing anywhere with two fingers"
msgstr "Stisknutím kdekoli dvěma prsty"

#: ui/main.qml:472
#, kde-format
msgctxt "@info shown below radio button"
msgid "Middle-click by pressing anywhere with three fingers."
msgstr "Prostřední tlačítko stisknutím obou dolních rohů."

#: ui/main.qml:484
#, kde-format
msgctxt ""
"@label for radiobutton group, begins the sentence 'middle-click by pressing "
"bottom-middle edge/by pressing anywhere with three fingers'"
msgid "Middle-click by:"
msgstr "Kliknutí prostředním tlačítkem myši"

#: ui/main.qml:487
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'middle-click by pressing bottom-middle "
"edge'"
msgid "Pressing bottom-middle edge"
msgstr "Stisknutím středu spodního okraje"

#: ui/main.qml:507
#, kde-format
msgctxt ""
"@option:radio completes the sentence 'middle-click by pressing bottom-left "
"and bottom-right corners'"
msgid "Pressing bottom-left and bottom-right corners"
msgstr "Stisknutím obou dolních rohů"

#: ui/main.qml:519
#, kde-format
msgctxt ""
"@option:check completes the sentence 'middle-click by pressing anywhere with "
"three fingers'"
msgid "Pressing anywhere with three fingers"
msgstr "Stisknutím kdekoli třemi prsty"

#: ui/main.qml:532
#, kde-format
msgctxt "@label for checkbox, tap-to-click"
msgid "Tapping:"
msgstr "Klepnutí:"

#: ui/main.qml:533
#, kde-format
msgctxt "@option:check"
msgid "Tap to click"
msgstr "Klepnutím klikněte"

#: ui/main.qml:548
#, kde-format
msgctxt "@option:check"
msgid "Allow dragging after tapping"
msgstr "Povolit přetahování po klepnutí"

#: ui/main.qml:560
#, kde-format
msgctxt "@info:tooltip from ContextualHelpButton"
msgid ""
"Tap, then tap and immediately slide finger over the touchpad to drag. Lift "
"finger to drop."
msgstr ""
"Klepněte, poté klepněte a okamžitě posuňte prst po touchpadu, abyste "
"přetáhli. Zvednutím prstu pusťte."

#: ui/main.qml:567
#, kde-format
msgctxt "@option:check"
msgid "Allow briefly lifting finger during tap-and-drag"
msgstr "Povolit krátké zvednutí prstu během klepnutí a přetažení"

#: ui/main.qml:580
#, kde-format
msgctxt "@title:group"
msgid "Two-finger tap:"
msgstr "Ťuknutí dvěma prsty:"

#: ui/main.qml:586
#, kde-format
msgctxt "@option:radio"
msgid "Right-click (three-finger tap to middle-click)"
msgstr "Pravé tlačítko (dotyk třemi prsty je prostřední tlačítko)"

#: ui/main.qml:587
#, kde-format
msgctxt "@option:radio"
msgid "Right-click"
msgstr "Kliknutí pravým tlačítkem myši"

#: ui/main.qml:608
#, kde-format
msgctxt "@option:radio"
msgid "Middle-click (three-finger tap to right-click)"
msgstr "Prostřední tlačítko (dotyk třemi prsty je pravé tlačítko)"

#: ui/main.qml:609
#, kde-format
msgctxt "@option:radio"
msgid "Middle-click"
msgstr "Kliknutí prostředním tlačítkem myši"

