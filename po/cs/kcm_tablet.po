msgstr "Uvolnění stisku tlačítka B=%1"

#: ui/Tester.qml:83
#, kde-format
msgctxt ""
"A tablet pad's dial has moved, V120 here refers to 'Value 120' which is a "
"technical term that should be kept as is"
msgid "Pad dial moved V120=%1"
msgstr "Posun tlačítka V120=%1"

#: ui/Tester.qml:219
#, kde-format
msgctxt "The tablet tester legend which is shown on start-up"
msgid ""
"## Legend:\n"
"# X, Y - event coordinate\n"
"# P - pressure\n"
"# TX,TY - tilt\n"
msgstr ""
"## Legenda:\n"
"# X, Y - souřadnice události\n"
"# P - tlak\n"
"# TX,TY - náklon\n"

