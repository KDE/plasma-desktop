msgid "Pen Calibration"
msgstr "Kalibrace pera"

#: ui/Calibration.qml:98
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Tap the targets again to confirm the new calibration.<nl/><nl/><b>Will "
"revert to default calibration in %1 seconds unless further action is taken.</"
"b>"
msgstr ""
"Klepněte znovu na cíle, abyste potvrdili novou kalibraci.<nl/><nl/><b>Pokud "
"neprovedete další akci, do %1 sekund se vrátí výchozí kalibrace.</b>"

#: ui/Calibration.qml:102
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Calibration is completed and saved.<nl/><nl/>Refine the calibration further "
"or close the window."
msgstr ""
"Kalibrace je dokončena a uložena.<nl/><nl/>Kalibraci dále upřesněte nebo "
"zavřete okno."

#: ui/Calibration.qml:105
#, kde-format
msgctxt "@info"
msgid "Tap the center of each target."
msgstr "Klepněte na střed každého cíle."

#: ui/Calibration.qml:112
#, kde-format
msgctxt "@action:button"
msgid "Refine Existing Calibration"
msgstr "Upravit existující kalibraci"

#: ui/Calibration.qml:121
#, kde-format
msgctxt "@action:button"
msgid "Reset and Try Again"
msgstr "Obnovit a zkusit znovu"

