#: ui/StylusTab.qml:222
#, kde-format
msgctxt "@label prefix for checkbox"
msgid "Left-handed mode:"
msgstr "Režim pro leváka:"

#: ui/StylusTab.qml:228
#, kde-format
msgctxt "@option:check Enable left-handed mode"
msgid "Enable"
msgstr "Povolit"

#: ui/StylusTab.qml:234
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Tells the device to accommodate left-handed users. Effects will vary by "
"device, but often it reverses the pad buttonsʼ functionality so the tablet "
"can be used upside-down."
msgstr ""
"Nastaví zařízení pro leváky. Účinky se liší podle zařízení, ale často se "
"obrátí funkce tlačítek na podložce, takže tablet lze používat obráceně."

#: ui/StylusTab.qml:246
#, kde-format
msgctxt ""
"'Mode' is the mode the stylus is in, pen (absolute) or mouse (relative)"
msgid "Mode:"
msgstr "Režim:"

#: ui/StylusTab.qml:254
#, kde-format
msgctxt ""
"@option:radio Pen mode, where the point on the screen is always where you "
"touch the stylus"
msgid "Pen"
msgstr "Pero"

#: ui/StylusTab.qml:259
#, kde-format
msgctxt "@info:whatsthis Accessible description"
msgid "The cursor follows where you touch the pen on the surface"
msgstr "Kurzor sleduje místo, kde se dotknete perem povrchu."

#: ui/StylusTab.qml:280
#, kde-format
msgctxt ""
"@option:radio Mouse mode, or like using the tablet like a giant touchpad"
msgid "Mouse"
msgstr "Myš"

#: ui/StylusTab.qml:285
#, kde-format
msgctxt "@info:whatsthis Accessible description"
msgid ""
"Moving the pen on the surface moves the cursor relative to where it was, "
"like a mouse"
msgstr ""
"Pohybem pera po povrchu se kurzor pohybuje relativně k místu, kde byl, "
"podobně jako u myši."

#: ui/StylusTab.qml:355
#, kde-format
msgctxt "@label prefix for pen pressure curve config"
msgid "Pen Pressure:"
msgstr "Tlak pera:"

#: ui/StylusTab.qml:415
#, kde-format
msgctxt "% of minimum pen pressure"
msgid "%1%"
msgstr "%1%"

#: ui/StylusTab.qml:423
#, kde-format
msgctxt "% of maximum pen pressure"
msgid "%1%"
msgstr "%1%"

#: ui/StylusTab.qml:434
#, kde-format
msgctxt "100% or maximum pen pressure"
msgid "100%"
msgstr "100%"

#: ui/StylusTab.qml:442
#, kde-format
msgctxt "0% or zero pen pressure"
msgid "0%"
msgstr "0%"

#: ui/StylusTab.qml:446
#, kde-format
msgctxt "@info"
msgid ""
"This curve controls the relationship between the pressure on the stylus and "
"the pressure values received by applications."
msgstr ""
"Tato křivka řídí vztah mezi tlakem na stylus a hodnotami tlaku přijímanými "
"aplikacemi."

#: ui/StylusTab.qml:451
#, kde-format
msgctxt "Pen pressure range"
msgid "Pressure Range:"
msgstr "Rozsah tlaku:"

#: ui/StylusTab.qml:478
#, kde-format
msgctxt "@info"
msgid ""
"Pressure above or below the threshold will be clamped, and this becomes the "
"new effective range."
msgstr ""
"Tlak nad nebo pod prahovou hodnotou bude omezen a stane se novým efektivním "
"rozsahem."

#: ui/StylusTab.qml:489
#, kde-format
msgctxt "@action:button Calibration in progress"
msgid "Calibration in Progress"
msgstr "Probíhá kalibrace"

#: ui/StylusTab.qml:491
#, kde-format
msgctxt "@action:button Calibrate the pen display"
msgid "Calibrate"
msgstr "Kalibrovat"

#: ui/StylusTab.qml:494
#, kde-format
msgctxt "@action:button Pen display doesn't support calibration"
msgid "Calibration Not Supported"
msgstr "Kalibrace není podporována"

#: ui/StylusTab.qml:535
#, kde-format
msgctxt "@action:button"
msgid "Reset Custom Calibration"
msgstr "Obnovit vlastní kalibraci"

#: ui/StylusTab.qml:550
#, kde-format
msgctxt "@info"
msgid ""
"You have manually calibrated this tablet. If it's no longer working "
"correctly, try resetting this first."
msgstr ""
"Tento tablet jste ručně kalibrovali. Pokud již nefunguje správně, zkuste jej "
"nejprve obnovit."

#: ui/Tester.qml:25
#, kde-format
