msgid "This folder will be used by default to open or save projects."
msgstr "दस्तावेजान् उद्घाटयितुं वा रक्षितुं वा पूर्वनिर्धारितरूपेण एतत् पुटं उपयुज्यते ।"

#: ui/UrlRequester.qml:74
#, kde-format
msgctxt "@action:button"
msgid "Choose new location"
msgstr "नूतनं स्थानं चिनुत"
