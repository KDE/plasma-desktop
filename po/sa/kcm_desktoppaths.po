#: ui/main.qml:53
#, kde-format
msgctxt "@label:textbox"
msgid "Desktop folder:"
msgstr "डेस्कटॉप् पुटम् :"

#: ui/main.qml:59
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder contains all the files you see on your desktop."
msgstr "अस्मिन् पुटे भवता भवतः डेस्कटॉप् मध्ये दृश्यमानानि सर्वाणि सञ्चिकानि सन्ति ।"

#: ui/main.qml:67
#, kde-format
msgctxt "@label:textbox"
msgid "Documents folder:"
msgstr "दस्तावेजपुटम् :"

#: ui/main.qml:73
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder will be used by default to open or save documents."
msgstr "दस्तावेजान् उद्घाटयितुं वा रक्षितुं वा पूर्वनिर्धारितरूपेण एतत् पुटं उपयुज्यते ।"

#: ui/main.qml:81
#, kde-format
msgctxt "@label:textbox"
msgid "Downloads folder:"
msgstr "डाउनलोड्स् समुच्चय:"

#: ui/main.qml:87
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder will be used by default to save your downloaded items."
msgstr "भवतः डाउनलोड् कृतानि वस्तूनि रक्षितुं पूर्वनिर्धारितरूपेण एतत् पुटं उपयुज्यते ।"

#: ui/main.qml:95
#, kde-format
msgctxt "@label:textbox"
msgid "Videos folder:"
msgstr "Videos पुटम् :"

#: ui/main.qml:101
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder will be used by default to open or save video files."
msgstr "एतत् पुटं पूर्वनिर्धारितरूपेण विडियो सञ्चिकाः उद्घाटयितुं वा रक्षितुं वा उपयुज्यते ।"

#: ui/main.qml:109
#, kde-format
msgctxt "@label:textbox"
msgid "Pictures folder:"
msgstr "चित्रपुटम् :"

#: ui/main.qml:115
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder will be used by default to open or save image files."
msgstr "इदं पुटं पूर्वनिर्धारितरूपेण चित्रसञ्चिकाः उद्घाटयितुं वा रक्षितुं वा उपयुज्यते ।"

#: ui/main.qml:123
#, kde-format
msgctxt "@label:textbox"
msgid "Music folder:"
msgstr "संगीतपुटम् :"

#: ui/main.qml:129
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder will be used by default to open or save music files."
msgstr "एतत् पुटं पूर्वनिर्धारितरूपेण सङ्गीतसञ्चिकाः उद्घाटयितुं वा रक्षितुं वा उपयुज्यते ।"

#: ui/main.qml:137
#, kde-format
msgctxt "@label:textbox"
msgid "Public folder:"
msgstr "सार्वजनिकपुटम् :"

#: ui/main.qml:143
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid ""
"This folder will be used by default for publicly-shared files when network "
"sharing is enabled."
msgstr ""
"यदा संजालसाझेदारी सक्षमा भवति तदा सार्वजनिकरूपेण साझासञ्चिकानां कृते एतत् पुटं "
"पूर्वनिर्धारितरूपेण उपयुज्यते ।"

#: ui/main.qml:151
#, kde-format
msgctxt "@label:textbox"
msgid "Templates folder:"
msgstr "टेम्पलेट्स फोल्डर:"

#: ui/main.qml:157
#, kde-format
msgctxt "@info:tooltip and accessible description"
msgid "This folder will be used by default to open or save file templates."
msgstr "सञ्चिकासारूप्याणि उद्घाटयितुं वा रक्षितुं वा पूर्वनिर्धारितरूपेण एतत् पुटं उपयुज्यते ।"

#: ui/main.qml:165
#, fuzzy, kde-format
